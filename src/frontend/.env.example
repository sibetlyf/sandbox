NEXT_PUBLIC_WS_HOST=localhost
NEXT_PUBLIC_WS_PORT=9999
NEXT_PUBLIC_WS_PASSWORD=lyf@123

# ============================================
# CORS 跨域配置（生产环境）
# ============================================

# 生产环境：设置允许的具体域名（推荐，提高安全性）
ALLOWED_ORIGIN=*

# 开发环境：允许所有源（默认，不设置则为 *）
ALLOWED_ORIGIN=*

# 多个域名示例（需要在 next.config.ts 中修改逻辑支持）
# ALLOWED_ORIGIN=http://101.200.215.109,https://yourdomain.com
