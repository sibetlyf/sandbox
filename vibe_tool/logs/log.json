{"type":"stream_event","uuid":"7ec8aa8b-9693-4737-b90d-d3634fd2cc5d","session_id":"e5b62fa8-354a-40ab-84e3-a5c5780e62cd","parent_tool_use_id":null,"event":{"type":"content_block_delta","index":0,"delta":{"type":"input_json_delta","partial_json":"{\"file_path\":\"H:\\\\MOMA\\\\qwen-code-main\\\\workspace\\\\tomato-timer\\\\src\\\\components\\\\StatsPanel.tsx\",\"content\":\"'use client';\\n\\nimport { useEffect, useState } from 'react';\\n\\ninterface StatsPanelProps {\\n  completedPomodoros: number;\\n}\\n\\nexport default function StatsPanel({ completedPomodoros }: StatsPanelProps) {\\n  const [weeklyData, setWeeklyData] = useState<number[]>([0, 0, 0, 0, 0, 0, 0]);\\n  const [totalFocusTime, setTotalFocusTime] = useState(0);\\n\\n  useEffect(() => {\\n    // 模拟生成一些历史数据（在实际应用中应该从localStorage或API获取）\\n    const today = new Date().getDay();\\n    const newWeeklyData = [...weeklyData];\\n    newWeeklyData[today] = completedPomodoros;\\n    setWeeklyData(newWeeklyData);\\n    setTotalFocusTime(completedPomodoros * 25); // 每个番茄钟25分钟\\n  }, [completedPomodoros]);\\n\\n  const days = ['日', '一', '二', '三', '四', '五', '六'];\\n  const maxPomodoros = Math.max(...weeklyData, 1);\\n\\n  return (\\n    <div className=\\\"bg-white/10 backdrop-blur-xl rounded-3xl p-6 border border-white/20 shadow-2xl\\\">\\n      <h2 className=\\\"text-2xl font-bold text-white mb-6\\\">📊 统计数据</h2>\\n\\n      {/* Overview Cards */}\\n      <div className=\\\"grid grid-cols-2 md:grid-cols-4 gap-4 mb-6\\\">\\n        <div className=\\\"bg-gradient-to-br from-orange-500/20 to-red-600/20 p-4 rounded-2xl border border-orange-500/30\\\">\\n          <p className=\\\"text-white/70 text-sm mb-1\\\">今日完成</p>\\n          <p className=\\\"text-3xl font-bold text-white\\\">{completedPomodoros}</p>\\n          <p className=\\\"text-white/50 text-xs\\\">个番茄钟</p>\\n        </div>\\n        <div className=\\\"bg-gradient-to-br from-green-500/20 to-teal-600/20 p-4 rounded-2xl border border-green-500/30\\\">\\n          <p className=\\\"text-white/70 text-sm mb-1\\\">总专注时长</p>\\n          <p className=\\\"text-3xl font-bold text-white\\\">{totalFocusTime}</p>\\n          <p className=\\\"text-white/50 text-xs\\\">分钟</p>\\n        </div>\\n        <div className=\\\"bg-gradient-to-br from-blue-500/20 to-purple-600/20 p-4 rounded-2xl border border-blue-500/30\\\">\\n          <p className=\\\"text-white/70 text-sm mb-1\\\">平均每天</p>\\n          <p className=\\\"text-3xl font-bold text-white\\\">{(completedPomodoros / Math.max(completedPomodoros > 0 ? 1 : 0, 1)).toFixed(1)}</p>\\n          <p className=\\\"text-white/50 text-xs\\\">个番茄钟</p>\\n        </div>\\n        <div className=\\\"bg-gradient-to-br from-purple-500/20 to-pink-600/20 p-4 rounded-2xl border border-purple-500/30\\\">\\n          <p className=\\\"text-white/70 text-sm mb-1\\\">最佳纪录</p>\\n          <p className=\\\"text-3xl font-bold text-white\\\">{Math.max(...weeklyData, completedPomodoros)}</p>\\n          <p className=\\\"text-white/50 text-xs\\\">个番茄钟</p>\\n        </div>\\n      </div>\\n\\n      {/* Weekly Chart */}\\n      <div className=\\\"bg-white/5 rounded-2xl p-4 border border-white/10\\\">\\n        <h3 className=\\\"text-lg font-semibold text-white mb-4\\\">本周统计</h3>\\n        <div className=\\\"flex items-end justify-between gap-2 h-40\\\">\\n          {weeklyData.map((count, index) => {\\n            const height = (count / maxPomodoros) * 100;\\n            const isToday = index === new Date().getDay();\\n            return (\\n              <div key={index} className=\\\"flex-1 flex flex-col items-center gap-2\\\">\\n                <span className=\\\"text-white/70 text-xs\\\">{count}</span>\\n                <div className=\\\"w-full bg-white/10 rounded-t-lg relative overflow-hidden\\\">\\n                  <div\\n                    className={`absolute bottom-0 w-full rounded-t-lg transition-all duration-500 ${\\n                      isToday\\n                        ? 'bg-gradient-to-t from-orange-500 to-red-600'\\n                        : 'bg-gradient-to-t from-blue-500 to-purple-600'\\n                    }`}\\n                    style={{ height: `${Math.max(height, 5)}%` }}\\n                  />\\n                </div>\\n                <span className=\\\"text-white/70 text-xs\\\">{days[index]}</span>\\n              </div>\\n            );\\n          })}\\n        </div>\\n      </div>\\n\\n      {/* Tips */}\\n      <div className=\\\"mt-6 p-4 bg-gradient-to-r from-yellow-500/20 to-orange-600/20 rounded-2xl border border-yellow-500/30\\\">\\n        <p className=\\\"text-white/90 text-sm\\\">\\n          💡 <strong className=\\\"text-white\\\">小贴士：</strong>\\n          建议每天完成4-8个番茄钟，每完成4个番茄钟后进行一次长休息。\\n        </p>\\n      </div>\\n    </div>\\n  );\\n}\"}"},"message_id":"321ef6be-38c2-4505-9b31-6f40424cd153"}}
