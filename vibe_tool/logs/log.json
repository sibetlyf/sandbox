{"type":"stream_event","uuid":"2151a881-e285-42c6-9650-5bebbe4e70d9","session_id":"e5b62fa8-354a-40ab-84e3-a5c5780e62cd","parent_tool_use_id":null,"event":{"type":"content_block_delta","index":0,"delta":{"type":"input_json_delta","partial_json":"{\"file_path\":\"H:\\\\MOMA\\\\qwen-code-main\\\\workspace\\\\tomato-timer\\\\scripts\\\\generate-images.js\",\"content\":\"const ZAI = require('z-ai-web-dev-sdk');\\nconst fs = require('fs');\\nconst path = require('path');\\n\\n// 输出目录\\nconst outputDir = path.join(__dirname, '../public/images');\\n\\n// 确保输出目录存在\\nif (!fs.existsSync(outputDir)) {\\n  fs.mkdirSync(outputDir, { recursive: true });\\n}\\n\\n// 图片生成配置\\nconst imageConfigs = [\\n  {\\n    name: 'focus-work',\\n    prompt: 'Professional person focused working at modern desk with laptop, minimalist office, warm lighting, productivity atmosphere, high quality photograph',\\n    size: '1344x768',\\n    description: '专注工作场景'\\n  },\\n  {\\n    name: 'coffee-break',\\n    prompt: 'Peaceful coffee break moment, steaming cup of coffee on wooden table, cozy atmosphere, relaxation, high quality photograph, warm tones',\\n    size: '1344x768',\\n    description: '休息场景'\\n  },\\n  {\\n    name: 'success-celebration',\\n    prompt: 'Business professional celebrating success, arms raised, achievement moment, bright lighting, motivational, high quality photograph',\\n    size: '1344x768',\\n    description: '成功庆祝'\\n  },\\n  {\\n    name: 'calendar-time',\\n    prompt: 'Modern calendar and clock illustration, time management concept, clean minimalist design, gradient colors, high quality',\\n    size: '1024x1024',\\n    description: '时间管理日历'\\n  },\\n  {\\n    name: 'weather-nature',\\n    prompt: 'Beautiful natural landscape with blue sky and fluffy clouds, serene atmosphere, high quality landscape photograph, vibrant colors',\\n    size: '1440x720',\\n    description: '天气风景'\\n  },\\n  {\\n    name: 'team-collaboration',\\n    prompt: 'Diverse team collaborating in modern office, brainstorming session, positive energy, professional photography, natural lighting',\\n    size: '1440x720',\\n    description: '团队协作'\\n  },\\n  {\\n    name: 'productivity-growth',\\n    prompt: 'Abstract visualization of productivity growth, upward trending graphs, geometric shapes, modern design, gradient blue and orange, high quality',\\n    size: '1024x1024',\\n    description: '生产力增长'\\n  },\\n  {\\n    name: 'goal-achievement',\\n    prompt: 'Person reaching for goal, metaphorical achievement, inspiring scene, golden light, motivational, high quality photograph',\\n    size: '1344x768',\\n    description: '目标达成'\\n  }\\n];\\n\\n// 生成单张图片\\nasync function generateImage(config) {\\n  try {\\n    console.log(`正在生成: ${config.description} (${config.name})...`);\\n    \\n    const zai = await ZAI.create();\\n    \\n    const response = await zai.images.generations.create({\\n      prompt: config.prompt,\\n      size: config.size\\n    });\\n\\n    if (!response.data || !response.data[0] || !response.data[0].base64) {\\n      throw new Error('Invalid response from image generation API');\\n    }\\n\\n    const imageBase64 = response.data[0].base64;\\n    const buffer = Buffer.from(imageBase64, 'base64');\\n    \\n    const filename = `${config.name}.png`;\\n    const outputPath = path.join(outputDir, filename);\\n    \\n    fs.writeFileSync(outputPath, buffer);\\n    \\n    console.log(`✓ 成功生成: ${filename} (${(buffer.length / 1024).toFixed(2)} KB)`);\\n    \\n    return {\\n      success: true,\\n      name: config.name,\\n      filename: filename,\\n      path: outputPath,\\n      size: buffer.length\\n    };\\n  } catch (error) {\\n    console.error(`✗ 生成失败: ${config.name} - ${error.message}`);\\n    return {\\n      success: false,\\n      name: config.name,\\n      error: error.message\\n    };\\n  }\\n}\\n\\n// 批量生成图片\\nasync function generateAllImages() {\\n  console.log('=== 开始生成番茄钟APP高清配图 ===\\\\n');\\n  console.log(`总共需要生成 ${imageConfigs.length} 张图片\\\\n`);\\n  \\n  const results = [];\\n  \\n  for (let i = 0; i < imageConfigs.length; i++) {\\n    const config = imageConfigs[i];\\n    console.log(`[${i + 1}/${imageConfigs.length}]`);\\n    \\n    const result = await generateImage(config);\\n    results.push(result);\\n    \\n    // 添加延迟避免API限流\\n    if (i < imageConfigs.length - 1) {\\n      console.log('等待2秒...\\\\n');\\n      await new Promise(resolve => setTimeout(resolve, 2000));\\n    }\\n  }\\n  \\n  // 汇总结果\\n  console.log('\\\\n=== 生成完成 ===\\\\n');\\n  const successCount = results.filter(r => r.success).length;\\n  const failCount = results.filter(r => !r.success).length;\\n  \\n  console.log(`成功: ${successCount} 张`);\\n  console.log(`失败: ${failCount} 张`);\\n  \\n  if (failCount > 0) {\\n    console.log('\\\\n失败的图片:');\\n    results.filter(r => !r.success).forEach(r => {\\n      console.log(`  - ${r.name}: ${r.error}`);\\n    });\\n  }\\n  \\n  console.log('\\\\n所有图片已保存到:', outputDir);\\n  \\n  return results;\\n}\\n\\n// 执行生成\\ngenerateAllImages()\\n  .then(results => {\\n    console.log('\\\\n图片生成任务完成！');\\n    process.exit(results.every(r => r.success) ? 0 : 1);\\n  })\\n  .catch(error => {\\n    console.error('发生错误:', error);\\n    process.exit(1);\\n  });\"}"},"message_id":"330bacde-0d16-4e4d-9c97-c8b67da72929"}}
