{"type":"assistant","uuid":"5f06d111-dfd5-44ed-9a50-d0d74f0fb484","session_id":"e5b62fa8-354a-40ab-84e3-a5c5780e62cd","parent_tool_use_id":null,"message":{"id":"5f06d111-dfd5-44ed-9a50-d0d74f0fb484","type":"message","role":"assistant","model":"glm-4-6-fp8","content":[{"type":"tool_use","id":"chatcmpl-tool-1768534055878-0","name":"write_file","input":{"file_path":"H:\\MOMA\\qwen-code-main\\workspace\\tomato-timer\\src\\components\\Calendar.tsx","content":"'use client';\n\nimport { useState } from 'react';\n\ninterface CalendarProps {}\n\nexport default function Calendar({}: CalendarProps) {\n  const [currentDate, setCurrentDate] = useState(new Date());\n  const [selectedDate, setSelectedDate] = useState<Date | null>(null);\n\n  const getDaysInMonth = (date: Date) => {\n    const year = date.getFullYear();\n    const month = date.getMonth();\n    const firstDay = new Date(year, month, 1);\n    const lastDay = new Date(year, month + 1, 0);\n    const daysInMonth = lastDay.getDate();\n    const startingDayOfWeek = firstDay.getDay();\n\n    const days: Array<{ day: number | null; date: Date }> = [];\n\n    // Add empty cells for days before the first day of the month\n    for (let i = 0; i < startingDayOfWeek; i++) {\n      days.push({ day: null, date: new Date(year, month, 1) });\n    }\n\n    // Add days of the month\n    for (let day = 1; day <= daysInMonth; day++) {\n      days.push({ day, date: new Date(year, month, day) });\n    }\n\n    return days;\n  };\n\n  const navigateMonth = (direction: 'prev' | 'next') => {\n    const newDate = new Date(currentDate);\n    newDate.setMonth(currentDate.getMonth() + (direction === 'next' ? 1 : -1));\n    setCurrentDate(newDate);\n  };\n\n  const isToday = (date: Date) => {\n    const today = new Date();\n    return (\n      date.getDate() === today.getDate() &&\n      date.getMonth() === today.getMonth() &&\n      date.getFullYear() === today.getFullYear()\n    );\n  };\n\n  const isSelected = (date: Date) => {\n    if (!selectedDate) return false;\n    return (\n      date.getDate() === selectedDate.getDate() &&\n      date.getMonth() === selectedDate.getMonth() &&\n      date.getFullYear() === selectedDate.getFullYear()\n    );\n  };\n\n  const handleDayClick = (date: Date) => {\n    setSelectedDate(date);\n  };\n\n  const days = getDaysInMonth(currentDate);\n  const weekDays = ['日', '一', '二', '三', '四', '五', '六'];\n  const months = [\n    '一月', '二月', '三月', '四月', '五月', '六月',\n    '七月', '八月', '九月', '十月', '十一月', '十二月'\n  ];\n\n  return (\n    <div className=\"bg-white/10 backdrop-blur-xl rounded-3xl p-6 border border-white/20 shadow-2xl\">\n      <h2 className=\"text-2xl font-bold text-white mb-4\">📅 日历</h2>\n\n      {/* Month Navigation */}\n      <div className=\"flex items-center justify-between mb-6\">\n        <button\n          onClick={() => navigateMonth('prev')}\n          className=\"w-10 h-10 bg-white/10 hover:bg-white/20 text-white rounded-xl text-xl font-bold transition-all duration-300\"\n        >\n          ‹\n        </button>\n        <h3 className=\"text-xl font-bold text-white\">\n          {currentDate.getFullYear()}年 {months[currentDate.getMonth()]}\n        </h3>\n        <button\n          onClick={() => navigateMonth('next')}\n          className=\"w-10 h-10 bg-white/10 hover:bg-white/20 text-white rounded-xl text-xl font-bold transition-all duration-300\"\n        >\n          ›\n        </button>\n      </div>\n\n      {/* Week Days */}\n      <div className=\"grid grid-cols-7 gap-1 mb-2\">\n        {weekDays.map(day => (\n          <div\n            key={day}\n            className=\"text-center text-white/70 text-sm font-semibold py-2\"\n          >\n            {day}\n          </div>\n        ))}\n      </div>\n\n      {/* Calendar Grid */}\n      <div className=\"grid grid-cols-7 gap-1\">\n        {days.map((item, index) => {\n          if (!item.day) {\n            return (\n              <div\n                key={index}\n                className=\"h-12\"\n              />\n            );\n          }\n\n          return (\n            <button\n              key={index}\n              onClick={() => handleDayClick(item.date)}\n              className={`\n                h-12 w-full rounded-xl font-semibold transition-all duration-300\n                ${isSelected(item.date)\n                  ? 'bg-gradient-to-r from-orange-500 to-red-600 text-white shadow-lg scale-105'\n                  : isToday(item.date)\n                  ? 'bg-white/20 text-white ring-2 ring-orange-500/50'\n                  : 'bg-white/5 hover:bg-white/15 text-white/90 hover:text-white'\n                }\n              `}\n            >\n              {item.day}\n            </button>\n          );\n        })}\n      </div>\n\n      {/* Selected Date Info */}\n      {selectedDate && (\n        <div className=\"mt-6 p-4 bg-gradient-to-r from-orange-500/20 to-red-600/20 rounded-2xl border border-orange-500/30\">\n          <p className=\"text-white/70 text-sm mb-1\">选中日期</p>\n          <p className=\"text-white font-semibold text-lg\">\n            {selectedDate.getFullYear()}年{selectedDate.getMonth() + 1}月{selectedDate.getDate()}日\n          </p>\n          <p className=\"text-white/50 text-sm mt-1\">\n            {weekDays[selectedDate.getDay()]}\n          </p>\n        </div>\n      )}\n\n      {/* Quick Actions */}\n      <div className=\"mt-4 space-y-2\">\n        <button\n          onClick={() => setSelectedDate(new Date())}\n          className=\"w-full py-2 bg-white/10 hover:bg-white/20 text-white rounded-xl font-medium transition-all duration-300 border border-white/20\"\n        >\n          📍 回到今天\n        </button>\n      </div>\n\n      {/* Productivity Stats Mock */}\n      <div className=\"mt-4 p-3 bg-white/5 rounded-xl border border-white/10\">\n        <p className=\"text-white/70 text-sm mb-2\">本月专注统计</p>\n        <div className=\"flex items-center gap-2\">\n          <div className=\"flex-1 h-2 bg-white/10 rounded-full overflow-hidden\">\n            <div className=\"h-full bg-gradient-to-r from-orange-500 to-red-600 rounded-full\" style={{ width: '65%' }} />\n          </div>\n          <span className=\"text-white font-semibold text-sm\">65%</span>\n        </div>\n        <p className=\"text-white/50 text-xs mt-1\">本月已完成 130 个番茄钟</p>\n      </div>\n    </div>\n  );\n}"}}],"stop_reason":"tool_use","usage":{"input_tokens":0,"output_tokens":0}}}
