{"type":"stream_event","uuid":"3f1b0c22-0bd7-4813-8ad5-a9995ed30aee","session_id":"e5b62fa8-354a-40ab-84e3-a5c5780e62cd","parent_tool_use_id":null,"event":{"type":"content_block_delta","index":0,"delta":{"type":"input_json_delta","partial_json":"{\"file_path\":\"H:\\\\MOMA\\\\qwen-code-main\\\\workspace\\\\tomato-timer\\\\src\\\\components\\\\MusicPlayer.tsx\",\"content\":\"'use client';\\n\\nimport { useState, useEffect, useRef } from 'react';\\n\\nconst tracks = [\\n  {\\n    id: 1,\\n    title: '专注冥想',\\n    artist: '自然之声',\\n    duration: 180,\\n    cover: '🎵'\\n  },\\n  {\\n    id: 2,\\n    title: '雨声白噪音',\\n    artist: '自然之声',\\n    duration: 240,\\n    cover: '🌧️'\\n  },\\n  {\\n    id: 3,\\n    title: '森林鸟鸣',\\n    artist: '自然之声',\\n    duration: 200,\\n    cover: '🐦'\\n  },\\n  {\\n    id: 4,\\n    title: '海浪声',\\n    artist: '自然之声',\\n    duration: 220,\\n    cover: '🌊'\\n  }\\n];\\n\\nexport default function MusicPlayer() {\\n  const [isPlaying, setIsPlaying] = useState(false);\\n  const [currentTrack, setCurrentTrack] = useState(0);\\n  const [progress, setProgress] = useState(0);\\n  const [volume, setVolume] = useState(70);\\n\\n  useEffect(() => {\\n    let interval: NodeJS.Timeout;\\n    if (isPlaying) {\\n      interval = setInterval(() => {\\n        setProgress(prev => {\\n          if (prev >= 100) {\\n            setIsPlaying(false);\\n            return 0;\\n          }\\n          return prev + 1;\\n        });\\n      }, tracks[currentTrack].duration * 10);\\n    }\\n    return () => clearInterval(interval);\\n  }, [isPlaying, currentTrack]);\\n\\n  const formatTime = (seconds: number) => {\\n    const mins = Math.floor(seconds / 60);\\n    const secs = seconds % 60;\\n    return `${mins}:${secs.toString().padStart(2, '0')}`;\\n  };\\n\\n  const handlePrevious = () => {\\n    setCurrentTrack(prev => (prev - 1 + tracks.length) % tracks.length);\\n    setProgress(0);\\n  };\\n\\n  const handleNext = () => {\\n    setCurrentTrack(prev => (prev + 1) % tracks.length);\\n    setProgress(0);\\n  };\\n\\n  const track = tracks[currentTrack];\\n\\n  return (\\n    <div className=\\\"bg-white/10 backdrop-blur-xl rounded-3xl p-6 border border-white/20 shadow-2xl\\\">\\n      <h2 className=\\\"text-2xl font-bold text-white mb-6\\\">🎵 背景音乐</h2>\\n\\n      {/* Current Track Info */}\\n      <div className=\\\"flex items-center gap-4 mb-6\\\">\\n        <div className=\\\"w-16 h-16 bg-gradient-to-br from-orange-500 to-red-600 rounded-2xl flex items-center justify-center text-3xl shadow-lg\\\">\\n          {track.cover}\\n        </div>\\n        <div className=\\\"flex-1\\\">\\n          <h3 className=\\\"text-white font-semibold text-lg\\\">{track.title}</h3>\\n          <p className=\\\"text-white/70 text-sm\\\">{track.artist}</p>\\n        </div>\\n      </div>\\n\\n      {/* Progress Bar */}\\n      <div className=\\\"mb-6\\\">\\n        <div className=\\\"flex items-center gap-3 mb-2\\\">\\n          <span className=\\\"text-white/70 text-sm\\\">\\n            {formatTime(Math.floor((progress / 100) * track.duration))}\\n          </span>\\n          <div className=\\\"flex-1 h-2 bg-white/10 rounded-full overflow-hidden\\\">\\n            <div\\n              className=\\\"h-full bg-gradient-to-r from-orange-500 to-red-600 rounded-full transition-all duration-300\\\"\\n              style={{ width: `${progress}%` }}\\n            />\\n          </div>\\n          <span className=\\\"text-white/70 text-sm\\\">\\n            {formatTime(track.duration)}\\n          </span>\\n        </div>\\n      </div>\\n\\n      {/* Controls */}\\n      <div className=\\\"flex items-center justify-center gap-4 mb-6\\\">\\n        <button\\n          onClick={handlePrevious}\\n          className=\\\"w-12 h-12 bg-white/10 hover:bg-white/20 text-white rounded-full transition-all duration-300 flex items-center justify-center\\\"\\n        >\\n          ⏮️\\n        </button>\\n        <button\\n          onClick={() => setIsPlaying(!isPlaying)}\\n          className=\\\"w-16 h-16 bg-gradient-to-r from-orange-500 to-red-600 hover:opacity-90 text-white rounded-full transition-all duration-300 shadow-lg hover:shadow-xl transform hover:scale-105 flex items-center justify-center text-2xl\\\"\\n        >\\n          {isPlaying ? '⏸️' : '▶️'}\\n        </button>\\n        <button\\n          onClick={handleNext}\\n          className=\\\"w-12 h-12 bg-white/10 hover:bg-white/20 text-white rounded-full transition-all duration-300 flex items-center justify-center\\\"\\n        >\\n          ⏭️\\n        </button>\\n      </div>\\n\\n      {/* Volume Control */}\\n      <div className=\\\"flex items-center gap-3\\\">\\n        <span className=\\\"text-white/70\\\">🔊</span>\\n        <div className=\\\"flex-1 h-2 bg-white/10 rounded-full overflow-hidden cursor-pointer\\\">\\n          <div\\n            className=\\\"h-full bg-white rounded-full transition-all duration-300\\\"\\n            style={{ width: `${volume}%` }}\\n          />\\n        </div>\\n        <span className=\\\"text-white/70 text-sm w-8\\\">{volume}</span>\\n      </div>\\n\\n      {/* Track List */}\\n      <div className=\\\"mt-6 space-y-2\\\">\\n        <h4 className=\\\"text-white/90 font-semibold mb-3\\\">播放列表</h4>\\n        {tracks.map((t, index) => (\\n          <button\\n            key={t.id}\\n            onClick={() => {\\n              setCurrentTrack(index);\\n              setProgress(0);\\n            }}\\n            className={`w-full flex items-center gap-3 p-3 rounded-xl transition-all duration-300 ${\\n              index === currentTrack\\n                ? 'bg-gradient-to-r from-orange-500/20 to-red-600/20 border border-orange-500/30'\\n                : 'bg-white/5 hover:bg-white/10'\\n            }`}\\n          >\\n            <span className=\\\"text-2xl\\\">{t.cover}</span>\\n            <div className=\\\"flex-1 text-left\\\">\\n              <p className={`font-medium ${index === currentTrack ? 'text-white' : 'text-white/90'}`}>\\n                {t.title}\\n              </p>\\n              <p className=\\\"text-white/70 text-sm\\\">{t.artist}</p>\\n            </div>\\n            {index === currentTrack && isPlaying && (\\n              <div className=\\\"flex gap-1\\\">\\n                <div className=\\\"w-1 h-4 bg-white rounded-full animate-pulse\\\" />\\n                <div className=\\\"w-1 h-4 bg-white rounded-full animate-pulse\\\" style={{ animationDelay: '0.2s' }} />\\n                <div className=\\\"w-1 h-4 bg-white rounded-full animate-pulse\\\" style={{ animationDelay: '0.4s' }} />\\n              </div>\\n            )}\\n          </button>\\n        ))}\\n      </div>\\n    </div>\\n  );\\n}\"}"},"message_id":"b074a30c-fb9c-4d11-851b-b94cd0c7d47e"}}
