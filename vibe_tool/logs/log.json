{"type":"assistant","uuid":"9f17b668-c1cc-4206-9cc1-12f51391baeb","session_id":"e5b62fa8-354a-40ab-84e3-a5c5780e62cd","parent_tool_use_id":null,"message":{"id":"9f17b668-c1cc-4206-9cc1-12f51391baeb","type":"message","role":"assistant","model":"glm-4-6-fp8","content":[{"type":"tool_use","id":"chatcmpl-tool-1768533973759-0","name":"write_file","input":{"file_path":"H:\\MOMA\\qwen-code-main\\workspace\\tomato-timer\\src\\components\\Timer.tsx","content":"'use client';\n\nimport { useState, useEffect, useCallback } from 'react';\nimport { useAtom } from 'jotai';\n\ninterface TimerProps {\n  onComplete: () => void;\n}\n\nexport default function Timer({ onComplete }: TimerProps) {\n  const [mode, setMode] = useState<'focus' | 'shortBreak' | 'longBreak'>('focus');\n  const [timeLeft, setTimeLeft] = useState(25 * 60);\n  const [isRunning, setIsRunning] = useState(false);\n  const [cycle, setCycle] = useState(0);\n\n  const modeConfig = {\n    focus: { time: 25 * 60, label: '专注', color: 'from-orange-500 to-red-600', emoji: '🎯' },\n    shortBreak: { time: 5 * 60, label: '短休息', color: 'from-green-500 to-teal-600', emoji: '☕' },\n    longBreak: { time: 15 * 60, label: '长休息', color: 'from-blue-500 to-purple-600', emoji: '🌟' },\n  };\n\n  const currentConfig = modeConfig[mode];\n\n  useEffect(() => {\n    let interval: NodeJS.Timeout;\n\n    if (isRunning && timeLeft > 0) {\n      interval = setInterval(() => {\n        setTimeLeft(prev => prev - 1);\n      }, 1000);\n    } else if (timeLeft === 0 && isRunning) {\n      handleComplete();\n    }\n\n    return () => clearInterval(interval);\n  }, [isRunning, timeLeft]);\n\n  const handleStartPause = () => {\n    setIsRunning(!isRunning);\n  };\n\n  const handleReset = () => {\n    setIsRunning(false);\n    setTimeLeft(currentConfig.time);\n  };\n\n  const handleComplete = () => {\n    setIsRunning(false);\n    if (mode === 'focus') {\n      onComplete();\n      // 自动切换到休息模式\n      const newCycle = cycle + 1;\n      setCycle(newCycle);\n      if (newCycle % 4 === 0) {\n        setMode('longBreak');\n      } else {\n        setMode('shortBreak');\n      }\n    } else {\n      setMode('focus');\n    }\n    setTimeLeft(modeConfig[mode === 'focus' ? 'longBreak' : 'focus'].time);\n  };\n\n  const formatTime = (seconds: number) => {\n    const mins = Math.floor(seconds / 60);\n    const secs = seconds % 60;\n    return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;\n  };\n\n  const progress = ((currentConfig.time - timeLeft) / currentConfig.time) * 100;\n  const circumference = 2 * Math.PI * 140;\n  const offset = circumference - (progress / 100) * circumference;\n\n  return (\n    <div className=\"bg-white/10 backdrop-blur-xl rounded-3xl p-8 border border-white/20 shadow-2xl\">\n      {/* Mode Selector */}\n      <div className=\"flex justify-center gap-3 mb-8\">\n        {(['focus', 'shortBreak', 'longBreak'] as const).map(m => (\n          <button\n            key={m}\n            onClick={() => {\n              if (!isRunning) {\n                setMode(m);\n                setTimeLeft(modeConfig[m].time);\n              }\n            }}\n            className={`px-4 py-2 rounded-xl font-semibold transition-all duration-300 ${\n              mode === m\n                ? `${currentConfig.color} text-white shadow-lg scale-105`\n                : 'bg-white/10 text-white/70 hover:bg-white/20'\n            }`}\n          >\n            {modeConfig[m].emoji} {modeConfig[m].label}\n          </button>\n        ))}\n      </div>\n\n      {/* Circular Timer */}\n      <div className=\"relative flex justify-center items-center mb-8\">\n        <div className=\"relative\">\n          <svg width=\"320\" height=\"320\" className=\"transform -rotate-90\">\n            {/* Background Circle */}\n            <circle\n              cx=\"160\"\n              cy=\"160\"\n              r=\"140\"\n              stroke=\"rgba(255,255,255,0.1)\"\n              strokeWidth=\"12\"\n              fill=\"none\"\n            />\n            {/* Progress Circle */}\n            <circle\n              cx=\"160\"\n              cy=\"160\"\n              r=\"140\"\n              stroke=\"url(#gradient)\"\n              strokeWidth=\"12\"\n              fill=\"none\"\n              strokeLinecap=\"round\"\n              strokeDasharray={circumference}\n              strokeDashoffset={offset}\n              style={{\n                transition: 'stroke-dashoffset 1s ease-in-out',\n              }}\n            />\n            <defs>\n              <linearGradient id=\"gradient\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n                <stop offset=\"0%\" stopColor={currentConfig.color.split(' ')[0].replace('from-', '')} />\n                <stop offset=\"100%\" stopColor={currentConfig.color.split(' ')[1].replace('to-', '')} />\n              </linearGradient>\n            </defs>\n          </svg>\n\n          {/* Time Display */}\n          <div className=\"absolute inset-0 flex flex-col items-center justify-center\">\n            <span className=\"text-7xl md:text-8xl font-bold text-white mb-2\" style={{ fontFamily: 'Inter, sans-serif', letterSpacing: '-0.02em' }}>\n              {formatTime(timeLeft)}\n            </span>\n            <span className=\"text-white/70 text-lg\">{currentConfig.label}</span>\n          </div>\n        </div>\n      </div>\n\n      {/* Controls */}\n      <div className=\"flex justify-center gap-4\">\n        <button\n          onClick={handleReset}\n          disabled={isRunning}\n          className=\"px-8 py-4 bg-white/10 hover:bg-white/20 disabled:opacity-50 text-white rounded-2xl font-semibold transition-all duration-300 backdrop-blur-lg border border-white/20\"\n        >\n          🔄 重置\n        </button>\n        <button\n          onClick={handleStartPause}\n          className={`px-12 py-4 bg-gradient-to-r ${currentConfig.color} hover:opacity-90 text-white rounded-2xl font-semibold transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:scale-105`}\n        >\n          {isRunning ? '⏸️ 暂停' : '▶️ 开始'}\n        </button>\n        <button\n          onClick={handleComplete}\n          disabled={isRunning}\n          className=\"px-8 py-4 bg-white/10 hover:bg-white/20 disabled:opacity-50 text-white rounded-2xl font-semibold transition-all duration-300 backdrop-blur-lg border border-white/20\"\n        >\n          ⏭️ 跳过\n        </button>\n      </div>\n\n      {/* Cycle Indicator */}\n      <div className=\"flex justify-center mt-6 gap-2\">\n        {[0, 1, 2, 3].map(i => (\n          <div\n            key={i}\n            className={`w-3 h-3 rounded-full transition-all duration-300 ${\n              i < cycle ? 'bg-white' : 'bg-white/20'\n            }`}\n          />\n        ))}\n      </div>\n    </div>\n  );\n}"}}],"stop_reason":"tool_use","usage":{"input_tokens":0,"output_tokens":0}}}
