<div className=\\\"max-w-7xl mx-auto\\\">\\n          {/* Header */}\\n          <header className=\\\"text-center mb-8\\\">\\n            <h1 className=\\\"text-5xl md:text-7xl font-bold text-white mb-2 tracking-tight\\\" style={{ fontFamily: 'Inter, sans-serif', letterSpacing: '-0.02em' }}>\\n              🍅 Tomato Timer\\n            </h1>\\n            <p className=\\\"text-white/80 text-lg md:text-xl\\\">专注此刻，提升效率</p>\\n          </header>\\n\\n          {/* Tab Navigation */}\\n          <div className=\\\"flex justify-center gap-4 mb-8\\\">\\n            <button\\n              onClick={() => setActiveTab('timer')}\\n              className={`px-6 py-3 rounded-2xl font-semibold transition-all duration-300 ${\\n                activeTab === 'timer'\\n                  ? 'bg-white/20 text-white backdrop-blur-lg shadow-lg'\\n                  : 'bg-white/10 text-white/70 hover:bg-white/20'\\n              }`}\\n            >\\n              计时器\\n            </button>\\n            <button\\n              onClick={() => setActiveTab('stats')}\\n              className={`px-6 py-3 rounded-2xl font-semibold transition-all duration-300 ${\\n                activeTab === 'stats'\\n                  ? 'bg-white/20 text-white backdrop-blur-lg shadow-lg'\\n                  : 'bg-white/10 text-white/70 hover:bg-white/20'\\n              }`}\\n            >\\n              统计\\n            </button>\\n            <button\\n              onClick={() => setActiveTab('settings')}\\n              className={`px-6 py-3 rounded-2xl font-semibold transition-all duration-300 ${\\n                activeTab === 'settings'\\n                  ? 'bg-white/20 text-white backdrop-blur-lg shadow-lg'\\n                  : 'bg-white/10 text-white/70 hover:bg-white/20'\\n              }`}\\n            >\\n              设置\\n            </button>\\n          </div>\\n\\n          {/* Main Grid */}\\n          <div className=\\\"grid grid-cols-1 lg:grid-cols-3 gap-6\\\">\\n            {/* Left Column - Timer & Tasks */}\\n            <div className=\\\"lg:col-span-2 space-y-6\\\">\\n              {activeTab === 'timer' && (\\n                <>\\n                  <Timer onComplete={handleCompletePomodoro} />\\n                  <TaskList\\n                    tasks={tasks}\\n                    onAddTask={handleAddTask}\\n                    onDeleteTask={handleDeleteTask}\\n                    currentTask={currentTask}\\n                    setCurrentTask={setCurrentTask}\\n                  />\\n                </>\\n              )}\\n\\n              {activeTab === 'stats' && (\\n                <StatsPanel completedPomodoros={completedPomodoros} />\\n              )}\\n\\n              {activeTab === 'settings' && (\\n                <SettingsPanel />\\n              )}\\n            </div>\\n\\n            {/* Right Column - Weather & Calendar */}\\n            <div className=\\\"space-y-6\\\">\\n              <WeatherCard />\\n              <Calendar />\\n            </div>\\n          </div>\\n        </div>\\n      </div>\\n    </main>\\n  );\\n}\"}"},"message_id":"4c36a37c-e6ba-431e-bcd1-53f9880d4779"}}
