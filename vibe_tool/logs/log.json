{"type":"stream_event","uuid":"acbbca32-a6fc-480e-affd-adc9490bd35e","session_id":"e5b62fa8-354a-40ab-84e3-a5c5780e62cd","parent_tool_use_id":null,"event":{"type":"content_block_delta","index":0,"delta":{"type":"input_json_delta","partial_json":"{\"file_path\":\"H:\\\\MOMA\\\\qwen-code-main\\\\workspace\\\\tomato-timer\\\\src\\\\components\\\\ImageGallery.tsx\",\"content\":\"'use client';\\n\\nimport { useState } from 'react';\\n\\nconst images = [\\n  {\\n    id: 1,\\n    name: 'focus-work',\\n    title: '专注工作',\\n    gradient: 'from-blue-600 to-indigo-700',\\n    pattern: 'grid',\\n    icon: '💼'\\n  },\\n  {\\n    id: 2,\\n    name: 'coffee-break',\\n    title: '休息时光',\\n    gradient: 'from-amber-600 to-orange-700',\\n    pattern: 'dots',\\n    icon: '☕'\\n  },\\n  {\\n    id: 3,\\n    name: 'success',\\n    title: '达成目标',\\n    gradient: 'from-green-600 to-emerald-700',\\n    pattern: 'waves',\\n    icon: '🎯'\\n  },\\n  {\\n    id: 4,\\n    name: 'calendar',\\n    title: '时间管理',\\n    gradient: 'from-purple-600 to-violet-700',\\n    pattern: 'circles',\\n    icon: '📅'\\n  },\\n  {\\n    id: 5,\\n    name: 'weather',\\n    title: '天气心情',\\n    gradient: 'from-cyan-600 to-sky-700',\\n    pattern: 'rain',\\n    icon: '🌤️'\\n  },\\n  {\\n    id: 6,\\n    name: 'team',\\n    title: '团队协作',\\n    gradient: 'from-pink-600 to-rose-700',\\n    pattern: 'lines',\\n    icon: '👥'\\n  },\\n  {\\n    id: 7,\\n    name: 'growth',\\n    title: '生产力增长',\\n    gradient: 'from-teal-600 to-cyan-700',\\n    pattern: 'arrows',\\n    icon: '📈'\\n  },\\n  {\\n    id: 8,\\n    name: 'achievement',\\n    title: '里程碑',\\n    gradient: 'from-orange-600 to-red-700',\\n    pattern: 'stars',\\n    icon: '🏆'\\n  }\\n];\\n\\nconst patterns = {\\n  grid: {\\n    backgroundImage: `linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px),\\n                      linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px)`,\\n    backgroundSize: '20px 20px'\\n  },\\n  dots: {\\n    backgroundImage: `radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px)`,\\n    backgroundSize: '20px 20px'\\n  },\\n  waves: {\\n    backgroundImage: `repeating-linear-gradient(45deg,\\n                      rgba(255,255,255,0.05) 0px,\\n                      rgba(255,255,255,0.05) 10px,\\n                      transparent 10px,\\n                      transparent 20px)`\\n  },\\n  circles: {\\n    backgroundImage: `radial-gradient(circle at 50% 50%, rgba(255,255,255,0.1) 0%, transparent 50%)`,\\n    backgroundSize: '40px 40px'\\n  },\\n  rain: {\\n    backgroundImage: `repeating-linear-gradient(180deg,\\n                      rgba(255,255,255,0.05) 0px,\\n                      rgba(255,255,255,0.05) 1px,\\n                      transparent 1px,\\n                      transparent 10px)`\\n  },\\n  lines: {\\n    backgroundImage: `repeating-linear-gradient(90deg,\\n                      rgba(255,255,255,0.05) 0px,\\n                      rgba(255,255,255,0.05) 2px,\\n                      transparent 2px,\\n                      transparent 10px)`\\n  },\\n  arrows: {\\n    backgroundImage: `linear-gradient(135deg,\\n                      rgba(255,255,255,0.1) 25%,\\n                      transparent 25%),\\n                      linear-gradient(225deg,\\n                      rgba(255,255,255,0.1) 25%,\\n                      transparent 25%),\\n                      linear-gradient(45deg,\\n                      rgba(255,255,255,0.1) 25%,\\n                      transparent 25%)`,\\n    backgroundSize: '30px 30px'\\n  },\\n  stars: {\\n    backgroundImage: `radial-gradient(circle at 20% 30%, rgba(255,255,255,0.2) 1px, transparent 1px),\\n                      radial-gradient(circle at 60% 70%, rgba(255,255,255,0.15) 1px, transparent 1px),\\n                      radial-gradient(circle at 80% 20%, rgba(255,255,255,0.18) 1px, transparent 1px)`,\\n    backgroundSize: '50px 50px'\\n  }\\n};\\n\\nexport default function ImageGallery() {\\n  const [selectedImage, setSelectedImage] = useState<number | null>(null);\\n\\n  return (\\n    <div className=\\\"bg-white/10 backdrop-blur-xl rounded-3xl p-6 border border-white/20 shadow-2xl\\\">\\n      <h2 className=\\\"text-2xl font-bold text-white mb-6\\\">🖼️ 灵感图库</h2>\\n\\n      {/* Image Grid */}\\n      <div className=\\\"grid grid-cols-2 md:grid-cols-4 gap-4\\\">\\n        {images.map((image) => (\\n          <div\\n            key={image.id}\\n            onClick={() => setSelectedImage(image.id)}\\n            className=\\\"group relative aspect-square rounded-2xl overflow-hidden cursor-pointer\\n                       bg-gradient-to-br transition-all duration-300 hover:scale-105 hover:shadow-2xl\\\"\\n            style={{\\n              background: `linear-gradient(135deg,\\n                var(--${image.gradient.split('-')[1]}-600),\\n                var(--${image.gradient.split('-')[2]}-700))`\\n            }}\\n          >\\n            {/* Pattern Overlay */}\\n            <div\\n              className=\\\"absolute inset-0 opacity-30\\\"\\n              style={patterns[image.pattern as keyof typeof patterns]}\\n            />\\n\\n            {/* Gradient Color */}\\n            <div\\n              className={`absolute inset-0 bg-gradient-to-br ${image.gradient}`}\\n            />\\n\\n            {/* Content */}\\n            <div className=\\\"absolute inset-0 flex flex-col items-center justify-center p-4\\\">\\n              <span className=\\\"text-6xl mb-2 transform transition-transform group-hover:scale-110\\\">\\n                {image.icon}\\n              </span>\\n              <span className=\\\"text-white font-semibold text-sm text-center\\\">\\n                {image.title}\\n              </span>\\n            </div>\\n\\n            {/* Hover Overlay */}\\n            <div className=\\\"absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center\\\">\\n              <span className=\\\"text-white font-semibold\\\">查看详情</span>\\n            </div>\\n          </div>\\n        ))}\\n      </div>\\n\\n      {/* Selected Image Detail */}\\n      {selectedImage && (\\n        <div\\n          className=\\\"fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex items-center justify-center p-4\\\"\\n          onClick={() => setSelectedImage(null)}\\n        >\\n          <div\\n            className=\\\"bg-white/10 backdrop-blur-xl rounded-3xl p-8 border border-white/20 shadow-2xl max-w-2xl w-full\\\"\\n            onClick={e => e.stopPropagation()}\\n          >\\n            <div\\n              className={`aspect-video rounded-2xl mb-6 bg-gradient-to-br ${images.find(i => i.id === selectedImage)!.gradient}`}\\n              style={patterns[images.find(i => i.id === selectedImage)!.pattern as keyof typeof patterns]}\\n            >\\n              <div className=\\\"absolute inset-0 flex items-center justify-center\\\">\\n                <span className=\\\"text-9xl\\\">{images.find(i => i.id === selectedImage)!.icon}</span>\\n              </div>\\n            </div>\\n\\n            <h3 className=\\\"text-3xl font-bold text-white mb-2\\\">\\n              {images.find(i => i.id === selectedImage)!.title}\\n            </h3>\\n            <p className=\\\"text-white/70 mb-6\\\">\\n              这是一个精心设计的视觉效果，展示了番茄钟的不同使用场景和理念。\\n            </p>\\n\\n            <div className=\\\"flex gap-4\\\">\\n              <button\\n                onClick={() => setSelectedImage(null)}\\n                className=\\\"flex-1 py-3 bg-gradient-to-r from-orange-500 to-red-600 hover:opacity-90 text-white rounded-2xl font-semibold transition-all duration-300\\\"\\n              >\\n                关闭\\n              </button>\\n              <button\\n                className=\\\"flex-1 py-3 bg-white/10 hover:bg-white/20 text-white rounded-2xl font-semibold transition-all duration-300 border border-white/20\\\"\\n              >\\n                下载\\n              </button>\\n            </div>\\n          </div>\\n        </div>\\n      )}\\n\\n      {/* Info Card */}\\n      <div className=\\\"mt-6 p-4 bg-gradient-to-r from-orange-500/20 to-red-600/20 rounded-2xl border border-orange-500/30\\\">\\n        <p className=\\\"text-white/90 text-sm\\\">\\n          💡 <strong>提示：</strong> 这些图片展示了番茄钟使用的不同场景，从专注工作到休息放松，\\n          从团队协作到个人成长。点击图片查看详情。\\n        </p>\\n      </div>\\n    </div>\\n  );\\n}\"}"},"message_id":"d9d615d2-9b16-4b8d-9b5e-962cbe0414ec"}}
