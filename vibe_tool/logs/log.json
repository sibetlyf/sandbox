enter justify-between\">\n            <div>\n              <p className=\"text-white font-semibold\">自动开始专注</p>\n              <p className=\"text-white/70 text-sm\">休息结束后自动开始专注</p>\n            </div>\n            <button\n              onClick={() =>\n                handleSettingChange(\n                  'autoStartFocus',\n                  !settings.autoStartFocus\n                )\n              }\n              className={`w-14 h-8 rounded-full p-1 transition-all duration-300 ${\n                settings.autoStartFocus\n                  ? 'bg-gradient-to-r from-orange-500 to-red-600'\n                  : 'bg-white/20'\n              }`}\n            >\n              <div\n                className={`w-6 h-6 bg-white rounded-full shadow-md transition-all duration-300 ${\n                  settings.autoStartFocus ? 'translate-x-6' : 'translate-x-0'\n                }`}\n              />\n            </button>\n          </div>\n\n          <div className=\"flex items-center justify-between\">\n            <div>\n              <p className=\"text-white font-semibold\">音效提醒</p>\n              <p className=\"text-white/70 text-sm\">计时结束时播放提示音</p>\n            </div>\n            <button\n              onClick={() =>\n                handleSettingChange('soundEnabled', !settings.soundEnabled)\n              }\n              className={`w-14 h-8 rounded-full p-1 transition-all duration-300 ${\n                settings.soundEnabled\n                  ? 'bg-gradient-to-r from-orange-500 to-red-600'\n                  : 'bg-white/20'\n              }`}\n            >\n              <div\n                className={`w-6 h-6 bg-white rounded-full shadow-md transition-all duration-300 ${\n                  settings.soundEnabled ? 'translate-x-6' : 'translate-x-0'\n                }`}\n              />\n            </button>\n          </div>\n        </div>\n\n        {/* Reset Button */}\n        <button\n          onClick={() =>\n            setSettings({\n           