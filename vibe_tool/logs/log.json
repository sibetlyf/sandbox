{"type":"stream_event","uuid":"322ee12e-acec-4310-97a6-4087fb0f4587","session_id":"e5b62fa8-354a-40ab-84e3-a5c5780e62cd","parent_tool_use_id":null,"event":{"type":"content_block_delta","index":0,"delta":{"type":"input_json_delta","partial_json":"{\"file_path\":\"H:\\\\MOMA\\\\qwen-code-main\\\\workspace\\\\tomato-timer\\\\src\\\\components\\\\SettingsPanel.tsx\",\"content\":\"'use client';\\n\\nimport { useState, useEffect } from 'react';\\n\\ninterface Settings {\\n  focusTime: number;\\n  shortBreakTime: number;\\n  longBreakTime: number;\\n  autoStartBreak: boolean;\\n  autoStartFocus: boolean;\\n  soundEnabled: boolean;\\n}\\n\\nexport default function SettingsPanel() {\\n  const [settings, setSettings] = useState<Settings>({\\n    focusTime: 25,\\n    shortBreakTime: 5,\\n    longBreakTime: 15,\\n    autoStartBreak: false,\\n    autoStartFocus: false,\\n    soundEnabled: true,\\n  });\\n\\n  const handleSettingChange = <K extends keyof Settings>(\\n    key: K,\\n    value: Settings[K]\\n  ) => {\\n    setSettings(prev => ({ ...prev, [key]: value }));\\n  };\\n\\n  return (\\n    <div className=\\\"bg-white/10 backdrop-blur-xl rounded-3xl p-6 border border-white/20 shadow-2xl\\\">\\n      <h2 className=\\\"text-2xl font-bold text-white mb-6\\\">⚙️ 设置</h2>\\n\\n      {/* Time Settings */}\\n      <div className=\\\"space-y-6\\\">\\n        <div>\\n          <label className=\\\"block text-white font-semibold mb-2\\\">⏱️ 专注时长（分钟）</label>\\n          <div className=\\\"flex items-center gap-4\\\">\\n            <button\\n              onClick={() =>\\n                handleSettingChange(\\n                  'focusTime',\\n                  Math.max(1, settings.focusTime - 5)\\n                )\\n              }\\n              className=\\\"w-12 h-12 bg-white/10 hover:bg-white/20 text-white rounded-xl text-xl font-bold transition-all duration-300\\\"\\n            >\\n              -\\n            </button>\\n            <span className=\\\"flex-1 text-center text-3xl font-bold text-white\\\">\\n              {settings.focusTime}\\n            </span>\\n            <button\\n              onClick={() =>\\n                handleSettingChange(\\n                  'focusTime',\\n                  Math.min(60, settings.focusTime + 5)\\n                )\\n              }\\n              className=\\\"w-12 h-12 bg-white/10 hover:bg-white/20 text-white rounded-xl text-xl font-bold transition-all duration-300\\\"\\n            >\\n              +\\n            </button>\\n          </div>\\n        </div>\\n\\n        <div>\\n          <label className=\\\"block text-white font-semibold mb-2\\\">☕ 短休息时长（分钟）</label>\\n          <div className=\\\"flex items-center gap-4\\\">\\n            <button\\n              onClick={() =>\\n                handleSettingChange(\\n                  'shortBreakTime',\\n                  Math.max(1, settings.shortBreakTime - 1)\\n                )\\n              }\\n              className=\\\"w-12 h-12 bg-white/10 hover:bg-white/20 text-white rounded-xl text-xl font-bold transition-all duration-300\\\"\\n            >\\n              -\\n            </button>\\n            <span className=\\\"flex-1 text-center text-3xl font-bold text-white\\\">\\n              {settings.shortBreakTime}\\n            </span>\\n            <button\\n              onClick={() =>\\n                handleSettingChange(\\n                  'shortBreakTime',\\n                  Math.min(15, settings.shortBreakTime + 1)\\n                )\\n              }\\n              className=\\\"w-12 h-12 bg-white/10 hover:bg-white/20 text-white rounded-xl text-xl font-bold transition-all duration-300\\\"\\n            >\\n              +\\n            </button>\\n          </div>\\n        </div>\\n\\n        <div>\\n          <label className=\\\"block text-white font-semibold mb-2\\\">🌟 长休息时长（分钟）</label>\\n          <div className=\\\"flex items-center gap-4\\\">\\n            <button\\n              onClick={() =>\\n        